# ============================================================
# Dockerfile.client - MCP Agent (Client) 컨테이너
# ============================================================
# MCP 에이전트가 담긴 이미지입니다.
# Ollama 서버와 MCP 서버는 별도 파드로 실행되며,
# 이 컨테이너는 두 서버에 HTTP로 연결합니다.
#
# 빌드 (mcp_test/ 루트에서 실행):
#   docker build -f deploy/Dockerfile.client -t mcp-agent:latest .
# 실행 (로컬 테스트):
#   docker run -it --env-file .env mcp-agent:latest
# ============================================================

FROM python:3.11-slim

LABEL description="MCP Agent - Ollama + Tool Call 에이전트"
LABEL version="1.0.0"

WORKDIR /app

# 의존성 설치
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 소스 코드 복사
COPY client/ ./client/
COPY server/ ./server/

# OpenShift는 자동으로 적절한 UID를 할당


# 기본 실행 명령
CMD ["python", "client/agent.py"]
