# ============================================================
# MCP Test - 환경변수 설정
# 이 파일을 복사하여 .env 파일을 만드세요.
#   cp .env.example .env
# ============================================================

# ──────────────────────────────────────────
# [1] LLM 설정 (Ollama - OpenShift GPU 파드)
# ──────────────────────────────────────────
# Ollama 서버 주소 (OpenShift 클러스터 내부 Service 주소)
OLLAMA_BASE_URL=http://service-gemma4.multi-agent.svc.cluster.local:11434

# Ollama는 API 키가 불필요하지만, openai 라이브러리가 값을 요구함
OLLAMA_API_KEY=ollama

# 사용할 모델명 (ollama pull로 미리 받아야 함)
# Gemma 계열: gemma3:4b, gemma3:12b, gemma4, gemma4:12b
# 경량 모델:  llama3.2:3b, phi4-mini, qwen2.5:7b
LLM_MODEL=gemma4:26b

# ──────────────────────────────────────────
# [2] MCP 서버 연결 방식
# ──────────────────────────────────────────
# http  → OpenShift에서 MCP 서버를 별도 파드로 실행 (기본값, 배포 시 사용)
# stdio → MCP 서버를 subprocess로 실행 (로컬 개발 시 사용)
TRANSPORT=http

# MCP 서버 HTTP 주소 (HTTP 모드일 때만 사용)
# OpenShift 클러스터 내부: http://mcp-tools-server:8080
# 로컬 테스트: http://localhost:8080
MCP_SERVER_URL=http://mcp-tools-server:8080

# ──────────────────────────────────────────
# [3] MCP 서버 자체 설정 (server.py가 읽는 값)
# ──────────────────────────────────────────
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8080

# ──────────────────────────────────────────
# [4] 날씨 API
# ──────────────────────────────────────────
# OpenWeatherMap 무료 API 키
# 발급: https://home.openweathermap.org/users/sign_up
